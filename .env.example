# NextAuth
NEXTAUTH_SECRET=replace-me-with-`openssl rand -base64 32`
NEXTAUTH_URL=http://localhost:3000
# next-auth v5 also reads AUTH_SECRET / AUTH_URL — set them too on Vercel:
AUTH_SECRET=replace-me-with-`openssl rand -base64 32`
AUTH_URL=http://localhost:3000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/manabi?retryWrites=true&w=majority

# Groq (server-only — never prefix with NEXT_PUBLIC_)
GROQ_API_KEY=gsk_xxx

# Upstash Redis (rate limiting). If unset, rate limiting is disabled.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
